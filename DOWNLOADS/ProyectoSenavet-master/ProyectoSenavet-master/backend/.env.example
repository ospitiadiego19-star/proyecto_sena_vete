# Puerto del servidor Express
PORT=3000

# Entorno: development | test | production
NODE_ENV=development

# ── Base de datos MySQL ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=datavet

# ── JWT ────────────────────────────────────────────────────────────────────────
# OBLIGATORIO en producción: cadena aleatoria larga y secreta
# Genera una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=reemplaza_con_un_secreto_seguro_en_produccion
JWT_EXPIRES_IN=8h
