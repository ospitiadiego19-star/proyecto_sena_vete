{
  "name": "datavet-api",
  "description": "API REST para sistema de gestión veterinaria con Node.js + MySQL",
  "repository": "https://github.com/ospitiadiego19-star/proyecto_sena_vete",
  "env": {
    "NODE_ENV": {
      "description": "Environment (development/production)",
      "value": "production"
    },
    "JWT_SECRET": {
      "description": "JWT secret key (generate with: node -e \"console.log(require('crypto').randomBytes(64).toString('hex'))\")",
      "required": true
    },
    "PORT": {
      "description": "Server port",
      "value": "8080"
    },
    "JWT_EXPIRES_IN": {
      "description": "JWT expiration time",
      "value": "8h"
    }
  },
  "addons": [
    {
      "plan": "mysql:8",
      "as": "DATABASE"
    }
  ],
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}
